# ==================================================
# Local RAG Chatbot v2 — Environment Variables
# Copy file này thành .env và điền giá trị thực
# ==================================================

# Tắt Gradio analytics (tránh timeout khi import)
GRADIO_ANALYTICS_ENABLED=false

# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (nếu đã cài)
RAG_LLM_PROVIDER=ollama
RAG_LLM_MODEL=qwen2.5:7b
RAG_LLM_BASE_URL=http://localhost:11434
RAG_LLM_TEMPERATURE=0.1
RAG_LLM_MAX_TOKENS=2048

# Embedding
RAG_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
RAG_EMBEDDING_DEVICE=cpu

# Chunking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_USE_SEMANTIC_CHUNKING=true
RAG_BREAKPOINT_THRESHOLD=0.85

# Retrieval
RAG_RETRIEVAL_K=6
RAG_RETRIEVAL_FETCH_K=20
RAG_USE_HYBRID_SEARCH=true
RAG_USE_RERANKER=true
RAG_RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# Vector store (Qdrant local)
RAG_QDRANT_PATH=./qdrant_data
RAG_COLLECTION_NAME=rag_docs
